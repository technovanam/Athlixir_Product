rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // Users can read/write their own analyses
    match /analyses/{analysisId} {
      allow read, write: if resource.data.userId == request.auth.uid;
    }

    // Athlete profiles owned by user
    match /athlete_profiles/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // Metrics are read-only for owner, write-only for backend
    match /metrics/{metricId} {
      allow read: if resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Scores
    match /scores/{scoreId} {
      allow read: if resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Benchmark results
    match /benchmark_results/{benchId} {
      allow read: if resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Injury risks
    match /injury_risks/{riskId} {
      allow read: if resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Recommendations
    match /recommendations/{recId} {
      allow read: if resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Reports
    match /reports/{reportId} {
      allow read: if resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Athlete progress
    match /athlete_progress/{docId} {
      allow read: if request.auth.uid == resource.data.userId;
      allow write: if false;
    }

    // Athlete evolution
    match /athlete_evolution/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // Goals
    match /goals/{goalId} {
      allow read: if resource.data.userId == request.auth.uid;
      allow write: if request.auth.uid == resource.data.userId;
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if resource.data.userId == request.auth.uid;
      allow write: if false;
    }
  }
}
